{
  "name": "@james.hankins/feedback-kit",
  "version": "0.2.2",
  "description": "Unified feedback and bug reporting widget for React/Next.js apps. Ideas post to Canny, bugs file in Linear.",
  "author": "James Hankins",
  "license": "MIT",
  "homepage": "https://james-hankins.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamesHankinsDev/feedback-kit.git"
  },
  "bugs": {
    "url": "https://github.com/JamesHankinsDev/feedback-kit/issues"
  },
  "keywords": [
    "feedback",
    "bug-report",
    "canny",
    "linear",
    "react",
    "nextjs",
    "widget"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./client": {
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
